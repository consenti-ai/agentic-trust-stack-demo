# Copy to .env.secretvm and fill in real values. This file is passed to
# `secretvm-cli vm create -e .env.secretvm` — it is NOT committed to git
# (see .gitignore) since it carries the real Blocksee API key.

# Note: there's no DOMAIN_NAME var here anymore — Traefik's routing is
# statically configured in secretvm-files/dynamic-config.yml instead (must be
# updated by hand to match whatever domain SecretVM assigns your VM).

# Server listens on 3000 inside the container (matches docker-compose-secretvm.yaml).
PORT=3000

# Real Blocksee REST API key. On your local Mac, server.js auto-loads this from
# claude_desktop_config.json — that file won't exist on the remote VM, so it
# must be supplied here instead (falls back to this env var).
BLOCKSEE_API_KEY=bsk_your_real_key_here

# Real PayPangea API key — same local-file auto-load / env var fallback as
# above. Used by the payment-watch poller, which attempts a real (currently
# broken, see server.js comments) PayPangea call once an agreement is fully
# signed by both parties.
PAYPANGEA_API_KEY=your_paypangea_key_here
